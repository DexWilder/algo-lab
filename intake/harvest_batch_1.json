    "automation_fitness_scoring": {
      "description": "7-dimension score for automation readiness",
      "dimensions": [
        "deterministic_entries: Entry rules produce same signal given same data",
        "deterministic_exits: Exit rules are fixed (ATR, time, level), not discretionary",
        "no_discretion: No human interpretation needed at any step",
        "session_clarity: Clear session start/end, no ambiguous timing",
        "fixed_stop_target: Stop and target levels are computable at entry time",
        "no_repaint: Signals use only confirmed/closed bar data",
        "order_compatible: Executable with market/limit/stop orders only"
      ],
      "scoring": "Each dimension: 0 (fail) or 1 (pass). Total 0-7. Score >= 5 = automation-ready."
    },
    "rejection_criteria": [
