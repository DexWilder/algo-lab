<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.fql.forward-trading</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/chasefisher/projects/Algo Trading/algo-lab/scripts/run_fql_forward.sh</string>
    </array>

    <!--
        DISABLED BY DEFAULT.
        DO NOT load this agent until you have:
        1. Set FORWARD_ENABLED="true" in run_fql_forward.sh
        2. Verified Databento API key is working
        3. Confirmed you accept the daily data cost (~$0.10-0.50/day)
        4. Run start_forward_day.sh manually at least 3 times successfully

        To load: launchctl load ~/Library/LaunchAgents/com.fql.forward-trading.plist
        To unload: launchctl unload ~/Library/LaunchAgents/com.fql.forward-trading.plist
    -->

    <!-- Weekdays at 06:25 ET (before 06:30 pre-market) -->
