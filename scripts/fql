    "notify-test": cmd_notify_test,
    "last": cmd_last,
    "funnel": lambda: _py("helper_funnel_audit.py", "--save"),
    "help": cmd_help,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        cmd_help()
        return

    cmd = sys.argv[1].lower()
    # Handle checkpoint --auto
    if cmd == "checkpoint" and len(sys.argv) > 2 and sys.argv[2] == "--auto":
        cmd_checkpoint_auto()
        return
    if cmd in COMMANDS:
        COMMANDS[cmd]()
    else:
        print(f"Unknown command: {cmd}")
        print(f"Run 'fql help' for available commands.")
        sys.exit(1)


if __name__ == "__main__":
    main()
