#!/usr/bin/env python3
"""FQL — single command layer for the Fisher Quant Lab platform.

Routines:
    fql morning         Doctor + daily brief (start of day)
    fql friday          Weekly reports + review (end of week)
    fql sunday          Harvest helpers + doctor (pre-week prep)
    fql checkpoint      April-style evaluation bundle

Core:
    fql status          Quick health + today's brief
    fql doctor          Full system health audit
    fql repair          Audit + auto-fix common issues
    fql daily           Show today's operator brief
    fql refresh         Regenerate all daily reports + alerts
    fql summary         One-screen snapshot of everything that matters

Operations:
    fql harvest         Run source helpers + show lead status
    fql weekly          Run weekly reports (gap dashboard, coverage, quality)
    fql components      Search strategy components (with filters)
    fql restart         Kickstart all launch agents
    fql alerts          Show active alerts
    fql review          Show probation scoreboard + challenger stack
    fql help            This help screen
"""

import os
import subprocess
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parent.parent
SCRIPTS = ROOT / "scripts"
INBOX = Path.home() / "openclaw-intake" / "inbox"


def _run(cmd, cwd=None, show_output=True):
    """Run a command, streaming output."""
    try:
        result = subprocess.run(
            cmd, cwd=cwd or str(ROOT),
            capture_output=not show_output,
            text=True, timeout=300
        )
        if not show_output:
            return result.stdout
        return result.returncode == 0
    except subprocess.TimeoutExpired:
        print("  Command timed out.")
        return False
    except Exception as e:
        print(f"  Error: {e}")
        return False


def _show_file(path):
    """Print a file's contents."""
    p = Path(path)
    if p.exists():
        print(p.read_text())
    else:
        print(f"  Not found: {p}")


def _py(script, *args):
    """Run a Python script with args."""
    return _run(["python3", str(SCRIPTS / script)] + list(args))


def _bash(script, *args):
    """Run a bash script with args."""
    return _run(["bash", str(SCRIPTS / script)] + list(args))


# ── Commands ──────────────────────────────────────────────────────────────

def cmd_status():
    """Quick health check + today's brief."""
    print("=" * 60)
    print("  FQL STATUS")
    print("=" * 60)
    print()
    _py("fql_doctor.py")
    print()
    print("-" * 60)
    print()
    _show_file(INBOX / "_operator_brief.md")


def cmd_doctor():
    """Full system health audit."""
    _py("fql_doctor.py")


def cmd_repair():
    """Audit + auto-fix common issues."""
    _py("fql_doctor.py", "--repair")


def cmd_daily():
    """Show today's operator brief."""
    brief = INBOX / "_operator_brief.md"
    if brief.exists():
        _show_file(brief)
    else:
        print("  No operator brief found. Run: fql refresh")


def cmd_refresh():
    """Regenerate all daily reports + alerts."""
    print("Refreshing FQL reports...")
    print()

    steps = [
        ("Alerts", lambda: _py("fql_alerts.py", "--save")),
        ("Probation scoreboard", lambda: _py("probation_scoreboard.py", "--save")),
        ("Challenger stack", lambda: _py("challenger_stack_review.py", "--save")),
        ("Rates review", lambda: _py("rates_challenger_review.py", "--save")),
        ("Operator brief", lambda: _py("operator_brief.py", "--save")),
        ("Recovery status", lambda: _bash("fql_recovery_status.sh")),
        ("System health", lambda: _py("fql_doctor.py")),
    ]

    for name, fn in steps:
        print(f"  {name}...", end=" ", flush=True)
        fn()
        print()

    print()
    print("All reports refreshed.")


def cmd_harvest():
    """Run source helpers + show lead status."""
    print("Running source helpers...")
    print()
    _bash("run_source_helpers.sh")
    print()
    print("-" * 60)
    print()
    manifest = INBOX / "source_leads" / "_manifest.json"
    if manifest.exists():
        import json
        data = json.load(open(manifest))
        runs = data.get("runs", [])
        if runs:
            last = runs[-1]
            print(f"Last fetch: {last.get('timestamp', '?')[:16]}")
            print(f"  GitHub:  {last.get('github_leads', 0)} leads")
            print(f"  Reddit:  {last.get('reddit_leads', 0)} leads")
            print(f"  YouTube: {last.get('youtube_leads', 0)} leads")
            print(f"  Blog:    {last.get('blog_leads', 0)} leads")
            print(f"  Digest:  {last.get('digest_leads', 0)} leads")
            print(f"  Total:   {last.get('total', 0)} leads")


def cmd_weekly():
    """Run weekly reports."""
    print("Running weekly reports...")
    print()

    steps = [
        ("Portfolio gap dashboard", lambda: _py("portfolio_gap_dashboard.py", "--save")),
        ("Harvest coverage audit", lambda: _py("harvest_coverage_audit.py", "--save")),
        ("Harvest quality review", lambda: _py("harvest_quality_review.py", "--days", "14", "--save")),
    ]

    for name, fn in steps:
        print(f"  {name}...", end=" ", flush=True)
        fn()
        print()

    print()
    print("Weekly reports generated.")


def cmd_components():
    """Search strategy components."""
    # Pass remaining args to component_search
    extra = sys.argv[2:] if len(sys.argv) > 2 else []
    _py("component_search.py", *extra)


def cmd_restart():
    """Kickstart all FQL launch agents."""
    uid = os.getuid()
    agents = [
        "ai.openclaw.gateway",
        "com.fql.watchdog",
        "com.fql.claw-control-loop",
        "com.fql.daily-research",
        "com.fql.twice-weekly-research",
        "com.fql.weekly-research",
        "com.fql.source-helpers",
    ]
    print("Restarting FQL services...")
    for label in agents:
        print(f"  {label}...", end=" ", flush=True)
        _run(["launchctl", "kickstart", "-k", f"gui/{uid}/{label}"], show_output=False)
        print("done")
    print()
    print("All services restarted. Run 'fql doctor' to verify.")


def cmd_alerts():
    """Show active alerts."""
    alerts = INBOX / "_alerts.md"
    if alerts.exists():
        _show_file(alerts)
    else:
        print("  No alerts file. Run: fql refresh")


def cmd_review():
    """Show probation + challenger reviews."""
    for name, filename in [
        ("PROBATION SCOREBOARD", "_probation_scoreboard.md"),
        ("CHALLENGER STACK", "_challenger_stack_review.md"),
    ]:
        path = INBOX / filename
        if path.exists():
            print("=" * 60)
            print(f"  {name}")
            print("=" * 60)
            _show_file(path)
            print()
        else:
            print(f"  {name}: not found. Run: fql refresh")


def cmd_morning():
    """Start-of-day routine: doctor + daily brief."""
    print("=" * 60)
    print("  FQL MORNING CHECK")
    print("=" * 60)
    print()
    _py("fql_doctor.py")
    print()
    _show_file(INBOX / "_operator_brief.md")
    _check_and_notify()


def cmd_friday():
    """End-of-week routine: weekly reports + review."""
    print("=" * 60)
    print("  FQL FRIDAY REVIEW")
    print("=" * 60)
    print()
    cmd_weekly()
    print()
    cmd_review()
    print()
    _show_file(INBOX / "_portfolio_gap_dashboard.md")


def cmd_sunday():
    """Pre-week prep: harvest + doctor."""
    print("=" * 60)
    print("  FQL SUNDAY PREP")
    print("=" * 60)
    print()
    cmd_harvest()
    print()
    _py("fql_doctor.py")


def cmd_checkpoint():
    """Run April-style evaluation bundle."""
    print("=" * 60)
    print("  FQL CHECKPOINT EVALUATION")
    print("=" * 60)
    print()

    # Refresh everything first
    print("Refreshing all reports...")
    _py("fql_alerts.py", "--save")
    _py("probation_scoreboard.py", "--save")
    _py("challenger_stack_review.py", "--save")
    _py("rates_challenger_review.py", "--save")
    _py("harvest_quality_review.py", "--days", "14", "--save")
    _py("harvest_coverage_audit.py", "--save")
    _py("portfolio_gap_dashboard.py", "--save")
    _py("operator_brief.py", "--save")
    _py("fql_doctor.py")
    print()

    # Show key outputs
    print("=" * 60)
    print("  SYSTEM HEALTH")
    print("=" * 60)
    _show_file(INBOX / "_system_health.md")

    print("=" * 60)
    print("  HARVEST QUALITY")
    print("=" * 60)
    _show_file(INBOX / "_harvest_quality_review.md")

    print("=" * 60)
    print("  PORTFOLIO GAPS")
    print("=" * 60)
    _show_file(INBOX / "_portfolio_gap_dashboard.md")

    print("=" * 60)
    print("  PROBATION SCOREBOARD")
    print("=" * 60)
    _show_file(INBOX / "_probation_scoreboard.md")

    print("=" * 60)
    print("  CHALLENGER STACK")
    print("=" * 60)
    _show_file(INBOX / "_challenger_stack_review.md")

    print("=" * 60)
    print("  ALERTS")
    print("=" * 60)
    _show_file(INBOX / "_alerts.md")

    print()
    print("Checklist: research/notes/april_3_evaluation_checklist.md")


def cmd_summary():
    """One-screen snapshot of everything that matters."""
    import json
    from datetime import datetime

    print("=" * 60)
    print("  FQL SUMMARY")
    print(f"  {datetime.now().strftime('%A, %Y-%m-%d %H:%M')}")
    print("=" * 60)
    print()

    # Health (compact)
    result = _run(["python3", str(SCRIPTS / "fql_doctor.py"), "--json"], show_output=False)
    try:
        data = json.loads(result)
        overall = data["overall"]
        degraded = [c["name"] for c in data["checks"] if c["status"] != "HEALTHY"]
        if degraded:
            print(f"  Health: {overall} — issues: {', '.join(degraded)}")
        else:
            print(f"  Health: {overall}")
    except Exception:
        print("  Health: could not check")

    # Alerts (compact)
    alerts_path = INBOX / "_alerts.md"
    if alerts_path.exists():
        text = alerts_path.read_text()
        a = text.count("[ALERT]")
        ac = text.count("[ACTION]")
        w = text.count("[WARN]")
        if a + ac > 0:
            print(f"  Alerts: {a} ALERT, {ac} ACTION, {w} WARN")
        elif w > 0:
            print(f"  Alerts: {w} warnings")
        else:
            print("  Alerts: none")

    # Account state
    acct_path = ROOT / "state" / "account_state.json"
    if acct_path.exists():
        try:
            acct = json.load(open(acct_path))
            eq = acct.get("equity", 0)
            hwm = acct.get("equity_hwm", 0)
            dd = hwm - eq
            pnl = acct.get("cumulative_pnl", 0)
            print(f"  Equity: ${eq:,.0f} | DD: ${dd:,.0f} | PnL: ${pnl:+,.0f}")
        except Exception:
            pass

    # Trades
    trade_path = ROOT / "logs" / "trade_log.csv"
    if trade_path.exists():
        try:
            import pandas as pd
            trades = pd.read_csv(trade_path)
            total = len(trades)
            today_str = datetime.now().strftime("%Y-%m-%d")
            today_n = len(trades[trades["date"] == today_str]) if "date" in trades.columns else 0
            print(f"  Trades: {total} total, {today_n} today")
        except Exception:
            pass

    # Probation (compact)
    reg_path = ROOT / "research" / "data" / "strategy_registry.json"
    if reg_path.exists():
        try:
            reg = json.load(open(reg_path))
            prob = [s for s in reg.get("strategies", []) if s.get("status") == "probation"]
            core = [s for s in reg.get("strategies", []) if s.get("status") == "core"]
            total = len(reg.get("strategies", []))
            print(f"  Portfolio: {len(core)} core, {len(prob)} probation, {total} registry")
        except Exception:
            pass

    # Source helpers
    manifest = INBOX / "source_leads" / "_manifest.json"
    if manifest.exists():
        try:
            data = json.load(open(manifest))
            runs = data.get("runs", [])
            if runs:
                last = runs[-1]
                print(f"  Leads: {last.get('total', 0)} from last fetch ({last.get('timestamp', '?')[:10]})")
        except Exception:
            pass

    # Next checkpoint
    print(f"  Next checkpoint: April 3, 2026")
    print()


def _check_and_notify():
    """Send macOS notification if ALERT or DEGRADED/BROKEN found."""
    alerts_path = INBOX / "_alerts.md"
    health_path = INBOX / "_system_health.md"

    messages = []

    if alerts_path.exists():
        text = alerts_path.read_text()
        alert_count = text.count("[ALERT]")
        action_count = text.count("[ACTION]")
        if alert_count > 0:
            messages.append(f"{alert_count} ALERT(s) require attention")
        if action_count > 0:
            messages.append(f"{action_count} decision(s) needed")

    if health_path.exists():
        text = health_path.read_text()
        if "BROKEN" in text:
            messages.append("System status: BROKEN")
        elif "DEGRADED" in text:
            messages.append("System status: DEGRADED")

    if messages:
        body = ". ".join(messages)
        try:
            subprocess.run([
                "osascript", "-e",
                f'display notification "{body}" with title "FQL Alert"'
            ], capture_output=True, timeout=5)
        except Exception:
            pass  # Notification is best-effort


def cmd_help():
    """Show help."""
    print(__doc__)


# ── Router ────────────────────────────────────────────────────────────────

COMMANDS = {
    # Routines
    "morning": cmd_morning,
    "friday": cmd_friday,
    "sunday": cmd_sunday,
    "checkpoint": cmd_checkpoint,
    # Core
    "status": cmd_status,
    "doctor": cmd_doctor,
    "repair": cmd_repair,
    "daily": cmd_daily,
    "refresh": cmd_refresh,
    "summary": cmd_summary,
    # Operations
    "harvest": cmd_harvest,
    "weekly": cmd_weekly,
    "components": cmd_components,
    "restart": cmd_restart,
    "alerts": cmd_alerts,
    "review": cmd_review,
    "help": cmd_help,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        cmd_help()
        return

    cmd = sys.argv[1].lower()
    if cmd in COMMANDS:
        COMMANDS[cmd]()
    else:
        print(f"Unknown command: {cmd}")
        print(f"Run 'fql help' for available commands.")
        sys.exit(1)


if __name__ == "__main__":
    main()
